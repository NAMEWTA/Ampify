{
  "name": "ampify",
  "displayName": "Ampify",
  "description": "Ampify: A practical VS Code extension for copier, skills, commands, git share, and compact MainView.",
  "version": "3.5.0",
  "publisher": "NAMEWTA",
  "repository": {
    "type": "git",
    "url": "https://github.com/NAMEWTA/Ampify"
  },
  "icon": "icon.png",
  "extensionKind": [
    "workspace"
  ],
  "engines": {
    "vscode": "^1.108.0"
  },
  "keywords": [
    "copy",
    "file name",
    "line number",
    "skills",
    "ai-agent",
    "skill-manager"
  ],
  "categories": [
    "Other",
    "AI"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ampify",
          "title": "Ampify",
          "icon": "$(window)"
        }
      ]
    },
    "views": {
      "ampify": [
        {
          "id": "ampify-main-view",
          "name": "Ampify",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "ampify.copy-relative-path-line",
        "title": "Copy Relative Path & Line (复制相对路径与行号)"
      },
      {
        "command": "ampify.copy-absolute-path-line",
        "title": "Copy Absolute Path & Line (复制绝对路径与行号)"
      },
      {
        "command": "ampify.skills.refresh",
        "title": "Refresh Skills",
        "icon": "$(refresh)"
      },
      {
        "command": "ampify.skills.search",
        "title": "Search Skills",
        "icon": "$(search)"
      },
      {
        "command": "ampify.skills.filterByTag",
        "title": "Filter by Tag",
        "icon": "$(filter)"
      },
      {
        "command": "ampify.skills.clearFilter",
        "title": "Clear Filter",
        "icon": "$(clear-all)"
      },
      {
        "command": "ampify.skills.create",
        "title": "Create New Skill",
        "icon": "$(add)"
      },
      {
        "command": "ampify.skills.import",
        "title": "Import Skill",
        "icon": "$(folder-library)"
      },
      {
        "command": "ampify.skills.apply",
        "title": "Copy to .agents/skills and .claude/skills",
        "icon": "$(play)"
      },
      {
        "command": "ampify.skills.preview",
        "title": "Preview SKILL.md",
        "icon": "$(open-preview)"
      },
      {
        "command": "ampify.skills.openFolder",
        "title": "Open Skill Source Folder",
        "icon": "$(folder-opened)"
      },
      {
        "command": "ampify.skills.delete",
        "title": "Delete Skill",
        "icon": "$(trash)"
      },
      {
        "command": "ampify.skills.remove",
        "title": "Remove from Project",
        "icon": "$(close)"
      },
      {
        "command": "ampify.skills.openFile",
        "title": "Open Skill File",
        "icon": "$(file-text)"
      },
      {
        "command": "ampify.commands.refresh",
        "title": "Refresh Commands",
        "icon": "$(refresh)"
      },
      {
        "command": "ampify.commands.search",
        "title": "Search Commands",
        "icon": "$(search)"
      },
      {
        "command": "ampify.commands.filterByTag",
        "title": "Filter by Tag",
        "icon": "$(filter)"
      },
      {
        "command": "ampify.commands.clearFilter",
        "title": "Clear Filter",
        "icon": "$(clear-all)"
      },
      {
        "command": "ampify.commands.create",
        "title": "Create New Command",
        "icon": "$(add)"
      },
      {
        "command": "ampify.commands.import",
        "title": "Import Command",
        "icon": "$(folder-library)"
      },
      {
        "command": "ampify.commands.apply",
        "title": "Copy to .agents/commands and .claude/commands",
        "icon": "$(play)"
      },
      {
        "command": "ampify.commands.preview",
        "title": "Preview Command",
        "icon": "$(open-preview)"
      },
      {
        "command": "ampify.commands.openFolder",
        "title": "Open Command Source Folder",
        "icon": "$(folder-opened)"
      },
      {
        "command": "ampify.commands.delete",
        "title": "Delete Command",
        "icon": "$(trash)"
      },
      {
        "command": "ampify.commands.remove",
        "title": "Remove from Project",
        "icon": "$(close)"
      },
      {
        "command": "ampify.agents.refresh",
        "title": "Refresh Agents",
        "icon": "$(refresh)"
      },
      {
        "command": "ampify.agents.search",
        "title": "Search Agents",
        "icon": "$(search)"
      },
      {
        "command": "ampify.agents.filterByTag",
        "title": "Filter Agents by Tag",
        "icon": "$(filter)"
      },
      {
        "command": "ampify.agents.clearFilter",
        "title": "Clear Agents Filter",
        "icon": "$(clear-all)"
      },
      {
        "command": "ampify.agents.create",
        "title": "Create New Agent",
        "icon": "$(add)"
      },
      {
        "command": "ampify.agents.import",
        "title": "Import Agent",
        "icon": "$(folder-library)"
      },
      {
        "command": "ampify.agents.apply",
        "title": "Copy to .agents/agents and .claude/agents",
        "icon": "$(play)"
      },
      {
        "command": "ampify.agents.preview",
        "title": "Preview Agent",
        "icon": "$(open-preview)"
      },
      {
        "command": "ampify.agents.open",
        "title": "Open Agent",
        "icon": "$(go-to-file)"
      },
      {
        "command": "ampify.agents.openFolder",
        "title": "Open Agent Source Folder",
        "icon": "$(folder-opened)"
      },
      {
        "command": "ampify.agents.delete",
        "title": "Delete Agent",
        "icon": "$(trash)"
      },
      {
        "command": "ampify.agents.remove",
        "title": "Remove Agent from Project",
        "icon": "$(close)"
      },
      {
        "command": "ampify.rules.refresh",
        "title": "Refresh Rules",
        "icon": "$(refresh)"
      },
      {
        "command": "ampify.rules.search",
        "title": "Search Rules",
        "icon": "$(search)"
      },
      {
        "command": "ampify.rules.filterByTag",
        "title": "Filter Rules by Tag",
        "icon": "$(filter)"
      },
      {
        "command": "ampify.rules.clearFilter",
        "title": "Clear Rules Filter",
        "icon": "$(clear-all)"
      },
      {
        "command": "ampify.rules.create",
        "title": "Create New Rule",
        "icon": "$(add)"
      },
      {
        "command": "ampify.rules.import",
        "title": "Import Rule",
        "icon": "$(folder-library)"
      },
      {
        "command": "ampify.rules.apply",
        "title": "Copy to .agents/rules and .claude/rules",
        "icon": "$(play)"
      },
      {
        "command": "ampify.rules.preview",
        "title": "Preview Rule",
        "icon": "$(open-preview)"
      },
      {
        "command": "ampify.rules.open",
        "title": "Open Rule",
        "icon": "$(go-to-file)"
      },
      {
        "command": "ampify.rules.openFolder",
        "title": "Open Rule Source Folder",
        "icon": "$(folder-opened)"
      },
      {
        "command": "ampify.rules.delete",
        "title": "Delete Rule",
        "icon": "$(trash)"
      },
      {
        "command": "ampify.rules.remove",
        "title": "Remove Rule from Project",
        "icon": "$(close)"
      },
      {
        "command": "ampify.gitShare.refresh",
        "title": "Refresh Git Share",
        "icon": "$(refresh)"
      },
      {
        "command": "ampify.gitShare.sync",
        "title": "Sync Git",
        "icon": "$(sync)"
      },
      {
        "command": "ampify.gitShare.pull",
        "title": "Pull",
        "icon": "$(cloud-download)"
      },
      {
        "command": "ampify.gitShare.push",
        "title": "Push",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "ampify.gitShare.commit",
        "title": "Commit",
        "icon": "$(git-commit)"
      },
      {
        "command": "ampify.gitShare.showDiff",
        "title": "Show Changes",
        "icon": "$(diff)"
      },
      {
        "command": "ampify.gitShare.editConfig",
        "title": "Edit Git Config",
        "icon": "$(gear)"
      },
      {
        "command": "ampify.gitShare.openConfigWizard",
        "title": "Configure Git",
        "icon": "$(settings-gear)"
      },
      {
        "command": "ampify.gitShare.openFolder",
        "title": "Open Git Share Folder",
        "icon": "$(folder-opened)"
      }
    ],
    "keybindings": [
      {
        "command": "ampify.copy-relative-path-line",
        "key": "ctrl+alt+c",
        "mac": "ctrl+alt+c",
        "when": "editorTextFocus"
      },
      {
        "command": "ampify.copy-absolute-path-line",
        "key": "ctrl+alt+v",
        "mac": "ctrl+alt+v",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "ampify.copy-relative-path-line"
        },
        {
          "command": "ampify.copy-absolute-path-line"
        }
      ],
      "view/title": [],
      "view/item/context": []
    },
    "configuration": {
      "title": "Ampify",
      "properties": {
        "ampify.language": {
          "type": "string",
          "enum": [
            "en",
            "zh-cn"
          ],
          "default": "zh-cn",
          "description": "Language for Ampify extension messages (Ampify 扩展的语言设置)"
        },
        "ampify.rootDir": {
          "type": "string",
          "default": "",
          "description": "Root directory for Ampify data storage. Leave empty to use ~/.vscode-ampify/ (Ampify 数据存储根目录)"
        },
        "ampify.skills.injectTarget": {
          "type": "string",
          "default": ".agents/skills/, .claude/skills/",
          "description": "Default target directories to inject skills into projects. Separate multiple directories with commas. (默认 Skill 注入目标目录，多个目录请用逗号分隔)"
        },
        "ampify.commands.injectTarget": {
          "type": "string",
          "default": ".agents/commands/, .claude/commands/",
          "description": "Default target directories to inject commands into projects. Separate multiple directories with commas. (默认 Command 注入目标目录，多个目录请用逗号分隔)"
        },
        "ampify.agents.injectTarget": {
          "type": "string",
          "default": ".agents/agents/, .claude/agents/",
          "description": "Default target directories to inject agents into projects. Separate multiple directories with commas. (默认 Agent 注入目标目录，多个目录请用逗号分隔)"
        },
        "ampify.rules.injectTarget": {
          "type": "string",
          "default": ".agents/rules/, .claude/rules/",
          "description": "Default target directories to inject rules into projects. Separate multiple directories with commas. (默认 Rule 注入目标目录，多个目录请用逗号分隔)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "npm run compile:extension && npm run build:webview",
    "precompile:extension": "node scripts/windows-out-precheck.js",
    "compile:extension": "tsc -p ./",
    "build:webview": "npm run typecheck:webview && vite build --config webview/vite.config.ts",
    "test:dashboard-search": "npm run compile:extension && node --test out/modules/mainView/bridges/dashboardSearchRanking.test.js",
    "typecheck:webview": "vue-tsc -p webview/tsconfig.json --noEmit",
    "watch": "concurrently \"npm:watch:extension\" \"npm:watch:webview\"",
    "watch:extension": "tsc -watch -p ./",
    "watch:webview": "vite build --config webview/vite.config.ts --watch",
    "lint": "npm run lint:extension && npm run lint:webview",
    "lint:extension": "eslint src --ext .ts",
    "lint:webview": "eslint webview/src --ext .ts,.vue"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.44",
    "element-plus": "^2.11.4",
    "pinia": "^3.0.3",
    "simple-git": "^3.22.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.1",
    "yaml": "^2.5.1"
  },
  "devDependencies": {
    "@types/node": "24.x",
    "@types/vscode": "^1.108.0",
    "@typescript-eslint/eslint-plugin": "^8.0.1",
    "@typescript-eslint/parser": "^8.0.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/compiler-sfc": "^3.5.13",
    "concurrently": "^9.1.2",
    "eslint": "^9.4.0",
    "eslint-plugin-vue": "^9.32.0",
    "typescript": "^5.6.3",
    "unplugin-vue-components": "^28.4.1",
    "vite": "^6.2.0",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^2.2.8"
  }
}
